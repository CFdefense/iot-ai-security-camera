# Copy to `.env` (or export in your shell) before running the services.

# REST API configuration
# Bind to LAN interface only, NOT 0.0.0.0 (see Architecture section 7).
API_HOST=127.0.0.1

# Use 5050 locally on macOS unless you disabled AirPlay Receiver (port 5000 conflicts).
API_PORT=5050

# Pre-shared key: required for REST guards and for the web dashboard (/login).
API_KEY=change-me-to-a-long-random-string

# Web dashboard (/login, /dashboard) — seeded into SQLite dashboard_users via db.inject_dashboard_credentials_from_env
SESSION_SECRET=change-this-to-a-long-random-string-for-flask-sessions
USER_EMAIL=email@change-me.com
USER_PASSWORD=password-change-me

# MQTT configuration
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_CLIENT_ID=pi-security-camera
HEARTBEAT_INTERVAL_SEC=60

# Detection configuration
SENSOR_ID=front_door_cam
# Cosine similarity gate for SFace embeddings (re-tune after switching from dlib; try 0.35–0.5 if matches fail).
MATCH_THRESHOLD=0.6

# Optional: directory with face_detection_yunet_2023mar.onnx + face_recognition_sface_2021dec.onnx (default: src/camera/picam/models/)
# FACE_MODEL_DIR=

# Serial (Arduino) port to be used for the serial bridge
SERIAL_PORT=/dev/ttyACM0

# Storage configuration
CAMERA_DB_PATH=./src/data/whitelist.sqlite